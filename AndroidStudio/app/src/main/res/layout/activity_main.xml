<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cunning"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reporta incidencias en tiempo real"
            android:textColor="#9CA3AF"
            android:textSize="14sp"
            android:layout_marginBottom="32dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp"
            android:gravity="center">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_feature_item"
                android:padding="12dp"
                android:layout_marginEnd="8dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_lock_lock" app:tint="#2563EB"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Seguro" android:textColor="#9CA3AF" android:textSize="11sp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_feature_item"
                android:padding="12dp"
                android:layout_marginHorizontal="4dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_dialog_map" app:tint="#2563EB"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Comunidad" android:textColor="#9CA3AF" android:textSize="11sp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_feature_item"
                android:padding="12dp"
                android:layout_marginStart="8dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/stat_notify_sync" app:tint="#2563EB"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="En vivo" android:textColor="#9CA3AF" android:textSize="11sp" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciar Sesión"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_dark"
                android:hint="tu@email.com"
                android:textColorHint="#4B5563"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textEmailAddress"
                android:textSize="14sp"
                android:drawableStart="@android:drawable/ic_dialog_email"
                android:drawablePadding="12dp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contraseña"
                android:textColor="#9CA3AF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_dark"
                android:hint="........"
                android:textColorHint="#4B5563"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="16dp"
                android:inputType="textPassword"
                android:textSize="14sp"
                android:drawableStart="@android:drawable/ic_lock_lock"
                android:drawablePadding="12dp"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Iniciar Sesión"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#2563EB"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Olvidaste tu contraseña?"
                android:textColor="#2563EB"
                android:textSize="12sp"
                android:layout_gravity="center"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnRegister"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿No tienes cuenta? Regístrate gratis"
            android:textColor="#2563EB"
            android:textAllCaps="false"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>