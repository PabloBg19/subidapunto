<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.cunning_javafx.HelloController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #111111; -fx-padding: 0 20 0 20;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Cunning Dashboard" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblUsuarioMain" text="Usuario: Invitado" textFill="#007bff">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>
                <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#onVolverClick" style="-fx-background-color: #ff4444; -fx-text-fill: white;" text="Cerrar Sesión" />
            </children>
        </HBox>
    </top>
    <left>
        <VBox prefHeight="530.0" prefWidth="200.0" spacing="15.0" style="-fx-background-color: #111111; -fx-padding: 20;" BorderPane.alignment="CENTER">
            <children>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onAddCommunityClick" style="-fx-background-color: #007bff; -fx-text-fill: white;" text="➕ Añadir Comunidad" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onInteractClick" style="-fx-background-color: #333333; -fx-text-fill: white;" text="💬 Chats" />
            </children>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: #000000; -fx-border-color: #000000;" BorderPane.alignment="CENTER">
            <content>
                <VBox fx:id="comunidadesContainer" alignment="TOP_CENTER" spacing="15.0" style="-fx-background-color: #000000; -fx-padding: 30;">
                    <children>
                        <Label text="Tus Comunidades" textFill="WHITE">
                            <font>
                                <Font size="20.0" />
                            </font>
                        </Label>
                        <Separator opacity="0.2" prefWidth="200.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>